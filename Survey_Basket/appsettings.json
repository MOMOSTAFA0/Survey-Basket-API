{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB; Database=surveyBasket;Integrated Security=true;",
    "HangfireConnection": "Server=(localdb)\\MSSQLLocalDB;Database=SurveyBasketJobs;Integrated Security=true;"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",

      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Hangfire": "Information"
      }
    },   
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "ApplicationName": "SurveyBasket"
    }
  },
  "AllowedHosts": "*",
  "JWT": {
    "Key": "",
    "Issuer": "SurvayBasketApp",
    "Audience": "SurvayBasketApp Users",
    "DurationInMinutes": 180
  },
  "Allowed Origins": [
    "http://localhost:3000",
    "http://localhost:19006"
  ],
  "MailSettings": {
    "Mail": "collin.jenkins62@ethereal.email",
    "DisplayName": "Survey Basket",
    "Host": "smtp.ethereal.email",
    "Port": 587
  },
  "HangFireSettings": {
    "UserName": "",
    "Password": ""
  }
}
